# Google / Gemini
GOOGLE_API_KEY=your_google_api_key_here

# Pinecone
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=embeddings-google
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Embedding model
EMBEDDING_MODEL=gemini-embedding-2-preview
EMBEDDING_DIMENSION=3072

# LLM — "gemini", "openai", or "claude"
LLM_PROVIDER=claude
GEMINI_LLM_MODEL=gemini-2.0-flash

# Only needed when LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Anthropic / Claude (used when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# Video processing
VIDEO_FRAME_INTERVAL=30      # sample every N frames
MAX_FRAMES_PER_VIDEO=20      # cap on frames extracted per video

# Audio processing
MAX_AUDIO_CHUNKS=50          # cap on transcript chunks embedded per audio file
AUDIO_TRANSCRIPTION_MODEL=gemini-2.0-flash

# Text chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval
TOP_K=5
